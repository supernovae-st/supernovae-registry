{
  "version": 3,
  "name": "supernovae-registry",
  "description": "Open-source package registry for AI workflows, agents, skills, prompts, jobs, schemas, MCP servers, and models",
  "homepage": "https://supernovae.sh",
  "types": {
    "workflow": {
      "description": "Nika YAML DAG workflows (.nika.yaml)",
      "file_pattern": "*.nika.yaml",
      "scopes": ["@workflows", "@nika"],
      "source_types": ["tarball"]
    },
    "agent": {
      "description": "Agent definitions (.agent.yaml, .agent.md)",
      "file_pattern": "*.agent.{yaml,md}",
      "scopes": ["@agents", "@nika"],
      "source_types": ["tarball"]
    },
    "skill": {
      "description": "Skill definitions (.skill.yaml, .skill.md)",
      "file_pattern": "*.skill.{yaml,md}",
      "scopes": ["@skills", "@nika"],
      "source_types": ["tarball"]
    },
    "prompt": {
      "description": "Prompt templates (prompts/*.md)",
      "file_pattern": "prompts/*.md",
      "scopes": ["@prompts", "@nika"],
      "source_types": ["tarball"]
    },
    "job": {
      "description": "Job triggers (.job.toml)",
      "file_pattern": "*.job.toml",
      "scopes": ["@jobs", "@nika"],
      "source_types": ["tarball"]
    },
    "schema": {
      "description": "NovaNet schema definitions (node/arc classes)",
      "file_pattern": "*.yaml",
      "scopes": ["@schemas", "@novanet"],
      "source_types": ["tarball"]
    },
    "mcp": {
      "description": "MCP (Model Context Protocol) servers",
      "scopes": ["@mcp"],
      "source_types": ["npm", "pypi", "binary"]
    },
    "model": {
      "description": "LLM models for local inference",
      "scopes": ["@models"],
      "source_types": ["ollama", "huggingface"]
    }
  },
  "packages": {
    "@nika/seo-audit": {
      "version": "0.1.0",
      "type": "workflow",
      "description": "SEO audit workflow with NovaNet entity context",
      "path": "packages/@nika/seo-audit",
      "pattern": "mcp-invoke",
      "schema": "@0.9"
    },
    "@workflows/dev-productivity/pr-description": {
      "version": "1.0.0",
      "type": "workflow",
      "description": "Generate PR description from git diff",
      "path": "packages/@workflows/dev-productivity/pr-description",
      "pattern": "linear-dag"
    },
    "@workflows/dev-productivity/changelog-generator": {
      "version": "1.0.0",
